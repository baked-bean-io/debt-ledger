#!/bin/sh
# Gentle nudge before pushing: if the commits you're about to push ADD new
# TODO/FIXME/HACK/XXX comments, offer a chance to triage them into the debt
# ledger first. Never fires for TODOs that already existed, never blocks
# scripts or CI (no terminal = no prompt), and "just push" is one keystroke.
#
# Install into a repo (see README "A nudge before you push"):
#   cp examples/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

ZERO=0000000000000000000000000000000000000000

total=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue # deleting a remote branch — nothing outgoing
  if [ "$remote_sha" = "$ZERO" ]; then
    range="$local_sha --not --remotes" # new branch: everything not already on the remote
  else
    range="$remote_sha..$local_sha"
  fi
  # shellcheck disable=SC2086
  count=$(git diff -U0 $range 2>/dev/null | grep '^+' | grep -vE '^\+\+\+' | grep -cE '\b(TODO|FIXME|HACK|XXX)\b')
  total=$((total + count))
done

if [ "$total" -gt 0 ] && [ -r /dev/tty ]; then
  printf 'techdebt: this push adds %s new TODO-style comment(s).\n' "$total" > /dev/tty
  printf 'Record them first with: techdebt scan --json > /tmp/c.json && techdebt triage --candidates /tmp/c.json\n' > /dev/tty
  printf 'Push anyway? [Y/n] ' > /dev/tty
  read -r answer < /dev/tty
  if [ "$answer" = "n" ] || [ "$answer" = "N" ]; then
    echo 'Push cancelled — happy triaging.' > /dev/tty
    exit 1
  fi
fi

exit 0
